rules_version = '2';

// TODO: Replace with production rules before launch. This file is a draft — it does NOT
// grant safe access by itself. Expect either:
// - Fine-grained Firestore rules (employer can only read linked employees / indices), or
// - Cloud Functions / backend that validates employer ↔ employee relationships.
//
// Production documentation notes (do not relax blindly):
// - `userEmailIndex/{emailLower}` below allows read for any authenticated user (`request.auth != null`).
//   In production, restrict reads e.g. to employers who have linked the employee, or serve lookups
//   only via Cloud Functions, so the index is not enumerable by arbitrary signed-in clients.
// - Employer access to `users/{employeeUid}/...` is gated here by `trackedEmployeeUids/{employeeUid}`.
//   Keep that collection accurate when adding/removing tracked employees so employers only read
//   data for people they actually track. See DATA_CONTRACT.md for path overview.
//
// MVP frontend assumes these collections/paths:
// - userEmailIndex/{emailLower}
// - users/{uid}/workspaces/{workspaceId}
// - users/{uid}/entries/{entryId}
// - users/{uid}/live/status
// - employers/{employerUid}/trackedEmployees/{id}
// - employers/{employerUid}/trackedEmployeeUids/{employeeUid}
// - employers/{employerUid}/groups/{groupId}

service cloud.firestore {
  match /databases/{database}/documents {

    function employerTracksUser(employeeUid) {
      return request.auth != null &&
        exists(/databases/$(database)/documents/employers/$(request.auth.uid)/trackedEmployeeUids/$(employeeUid));
    }

    // Employer panel may create/update time entries (soft delete via isDeleted); no hard deletes.
    function employerEntryBillingPercentOk() {
      return !('billingRatePercent' in request.resource.data) ||
        (request.resource.data.billingRatePercent is int &&
          (request.resource.data.billingRatePercent == 50 ||
            request.resource.data.billingRatePercent == 80 ||
            request.resource.data.billingRatePercent == 100 ||
            request.resource.data.billingRatePercent == 150 ||
            request.resource.data.billingRatePercent == 200)) ||
        (request.resource.data.billingRatePercent is float &&
          (request.resource.data.billingRatePercent == 50.0 ||
            request.resource.data.billingRatePercent == 80.0 ||
            request.resource.data.billingRatePercent == 100.0 ||
            request.resource.data.billingRatePercent == 150.0 ||
            request.resource.data.billingRatePercent == 200.0));
    }

    function employerEntryCoreFieldsValid() {
      let e = request.resource.data;
      return e.workspaceId is string &&
        e.workspaceId.size() > 0 &&
        e.workspaceId.size() <= 128 &&
        e.start is timestamp &&
        e.updatedAt is timestamp &&
        e.isDeleted is bool &&
        (!('end' in e) || e.end == null || (e.end is timestamp && e.end > e.start)) &&
        (!('mode' in e) || (e.mode is string && e.mode.size() <= 64)) &&
        (!('taskTitle' in e) || (e.taskTitle is string && e.taskTitle.size() <= 4000)) &&
        (!('note' in e) || (e.note is string && e.note.size() <= 4000)) &&
        (!('entryType' in e) || (e.entryType is string && e.entryType.size() <= 64)) &&
        (!('createdVia' in e) || (e.createdVia is string && e.createdVia.size() <= 64)) &&
        (!('createdBy' in e) || (e.createdBy is string && e.createdBy.size() <= 128)) &&
        (!('editedBy' in e) || (e.editedBy is string && e.editedBy.size() <= 128)) &&
        (!('editedAt' in e) || e.editedAt is timestamp) &&
        (!('isBillable' in e) || e.isBillable is bool) &&
        employerEntryBillingPercentOk();
    }

    function employerEntryCreateValid() {
      let e = request.resource.data;
      return employerEntryCoreFieldsValid() &&
        e.createdBy == request.auth.uid &&
        e.createdVia == 'employer_panel';
    }

    function employerEntryUpdateValid() {
      return employerEntryCoreFieldsValid() &&
        (!('editedBy' in request.resource.data) ||
          request.resource.data.editedBy == request.auth.uid);
    }

    /// Employee writes their own `users/{userId}/entries` (mobile). Same field shape as employer edits.
    function employeeOwnTimeEntryWrite() {
      return request.auth != null &&
        request.auth.uid == userId &&
        employerEntryCoreFieldsValid();
    }

    match /users/{userId} {
      match /live/status {
        allow read: if employerTracksUser(userId);
        allow write: if false;
      }
      match /workspaces/{wid} {
        allow read: if employerTracksUser(userId);
        allow write: if false;
      }
      match /entries/{eid} {
        allow read: if request.auth != null &&
          (request.auth.uid == userId || employerTracksUser(userId));
        allow create: if employeeOwnTimeEntryWrite() ||
          (employerTracksUser(userId) && employerEntryCreateValid());
        allow update: if employeeOwnTimeEntryWrite() ||
          (employerTracksUser(userId) && employerEntryUpdateValid());
        allow delete: if false;
      }
      match /{document=**} {
        allow read: if false;
        allow write: if false;
      }
    }

    match /userEmailIndex/{email} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /employers/{employerId}/trackedEmployees/{tid} {
      allow read, write: if request.auth != null && request.auth.uid == employerId;
    }
    match /employers/{employerId}/trackedEmployeeUids/{employeeUid} {
      allow read, write: if request.auth != null && request.auth.uid == employerId;
    }
    match /employers/{employerId}/groups/{gid} {
      allow read, write: if request.auth != null && request.auth.uid == employerId;
    }
    match /employers/{employerId}/{document=**} {
      allow read, write: if false;
    }
  }
}
