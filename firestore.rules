rules_version = '2';

// TODO: Replace with production rules before launch. This file is a draft — it does NOT
// grant safe access by itself. Expect either:
// - Fine-grained Firestore rules (employer can only read linked employees / indices), or
// - Cloud Functions / backend that validates employer ↔ employee relationships.
//
// MVP frontend assumes these collections/paths:
// - userEmailIndex/{emailLower}
// - users/{uid}/workspaces/{workspaceId}
// - users/{uid}/entries/{entryId}
// - users/{uid}/live/status
// - employers/{employerUid}/trackedEmployees/{id}
// - employers/{employerUid}/trackedEmployeeUids/{employeeUid}
// - employers/{employerUid}/groups/{groupId}

service cloud.firestore {
  match /databases/{database}/documents {

    function employerTracksUser(employeeUid) {
      return request.auth != null &&
        exists(/databases/$(database)/documents/employers/$(request.auth.uid)/trackedEmployeeUids/$(employeeUid));
    }

    match /users/{userId} {
      match /live/status {
        allow read: if employerTracksUser(userId);
        allow write: if false;
      }
      match /workspaces/{wid} {
        allow read: if employerTracksUser(userId);
        allow write: if false;
      }
      match /entries/{eid} {
        allow read: if employerTracksUser(userId);
        allow write: if false;
      }
      match /{document=**} {
        allow read: if false;
        allow write: if false;
      }
    }

    match /userEmailIndex/{email} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /employers/{employerId}/trackedEmployees/{tid} {
      allow read, write: if request.auth != null && request.auth.uid == employerId;
    }
    match /employers/{employerId}/trackedEmployeeUids/{employeeUid} {
      allow read, write: if request.auth != null && request.auth.uid == employerId;
    }
    match /employers/{employerId}/groups/{gid} {
      allow read, write: if request.auth != null && request.auth.uid == employerId;
    }
    match /employers/{employerId}/{document=**} {
      allow read, write: if false;
    }
  }
}
